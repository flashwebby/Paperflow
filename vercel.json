"use client";

import { useState, useRef, useEffect } from "react";
import { useRouter, useSearchParams } from "next/navigation";
import { cn } from "@/lib/utils";

const SUGGESTIONS = [
  "attention mechanism transformer",
  "diffusion models image generation",
  "large language model alignment",
  "quantum error correction",
  "graph neural networks",
  "reinforcement learning from human feedback",
  "vision language models",
  "neural scaling laws",
];

interface SearchBarProps {
  defaultValue?: string;
  autoFocus?: boolean;
  size?: "sm" | "lg";
  onSearch?: (query: string) => void;
}

export function SearchBar({
  defaultValue = "",
  autoFocus = false,
  size = "lg",
  onSearch,
}: SearchBarProps) {
  const router = useRouter();
  const [query, setQuery] = useState(defaultValue);
  const [focused, setFocused] = useState(false);
  const [selectedIdx, setSelectedIdx] = useState(-1);
  const inputRef = useRef<HTMLInputElement>(null);

  const suggestions = SUGGESTIONS.filter(
    (s) => s.toLowerCase().includes(query.toLowerCase()) && query.length > 1
  ).slice(0, 5);

  const showSuggestions = focused && suggestions.length > 0 && query.length > 1;

  useEffect(() => {
    setQuery(defaultValue);
  }, [defaultValue]);

  const handleSubmit = (val?: string) => {
    const q = val ?? query;
    if (!q.trim()) return;
    if (onSearch) {
      onSearch(q.trim());
    } else {
      router.push(`/search?q=${encodeURIComponent(q.trim())}`);
    }
    setFocused(false);
  };

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (e.key === "ArrowDown") {
      e.preventDefault();
      setSelectedIdx((i) => Math.min(i + 1, suggestions.length - 1));
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      setSelectedIdx((i) => Math.max(i - 1, -1));
    } else if (e.key === "Enter") {
      if (selectedIdx >= 0 && suggestions[selectedIdx]) {
        setQuery(suggestions[selectedIdx]);
        handleSubmit(suggestions[selectedIdx]);
      } else {
        handleSubmit();
      }
    } else if (e.key === "Escape") {
      setFocused(false);
      inputRef.current?.blur();
    }
  };

  return (
    <div className="relative w-full">
      <div
        className={cn(
          "relative flex items-center rounded-xl border transition-all duration-200",
          focused
            ? "border-amber-500/50 shadow-[0_0_0_3px_rgba(245,158,11,0.1)]"
            : "border-ink-700 hover:border-ink-600",
          size === "lg" ? "h-14" : "h-10",
          "bg-ink-900"
        )}
      >
        <svg
          className={cn(
            "flex-shrink-0 text-ink-500",
            size === "lg" ? "w-5 h-5 ml-4" : "w-4 h-4 ml-3"
          )}
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            strokeLinecap="round"
            strokeLinejoin="round"
            strokeWidth={2}
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
          />
        </svg>

        <input
          ref={inputRef}
          type="text"
          value={query}
          onChange={(e) => {
            setQuery(e.target.value);
            setSelectedIdx(-1);
          }}
          onFocus={() => setFocused(true)}
          onBlur={() => setTimeout(() => setFocused(false), 150)}
          onKeyDown={handleKeyDown}
          placeholder="Search papers, topics, authors…"
          autoFocus={autoFocus}
          className={cn(
            "flex-1 bg-transparent text-ink-100 placeholder-ink-500 focus:outline-none",
            size === "lg" ? "text-base px-3" : "text-sm px-2"
          )}
        />

        {query && (
          <button
            onClick={() => {
              setQuery("");
              inputRef.current?.focus();
            }}
            className="mr-2 p-1 text-ink-500 hover:text-ink-300 transition-colors"
          >
            <svg className="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        )}

        <button
          onClick={() => handleSubmit()}
          className={cn(
            "flex-shrink-0 mr-1.5 btn-amber text-sm",
            size === "lg" ? "px-5 py-2" : "px-3 py-1.5 text-xs"
          )}
        >
          Search
        </button>
      </div>

      {/* Suggestions dropdown */}
      {showSuggestions && (
        <div className="absolute top-full left-0 right-0 mt-1.5 bg-ink-900 border border-ink-700 rounded-xl shadow-2xl z-50 overflow-hidden">
          {suggestions.map((s, i) => (
            <button
              key={s}
              onMouseDown={() => {
                setQuery(s);
                handleSubmit(s);
              }}
              className={cn(
                "w-full text-left px-4 py-2.5 text-sm transition-colors flex items-center gap-2",
                i === selectedIdx
                  ? "bg-ink-800 text-amber-300"
                  : "text-ink-300 hover:bg-ink-800 hover:text-ink-100"
              )}
            >
              <svg className="w-3.5 h-3.5 text-ink-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              {s}
            </button>
          ))}
        </div>
      )}
    </div>
  );
}
